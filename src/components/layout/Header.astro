---
import Icon from '../ui/Icon.astro';
import MobileNav from './MobileNav.astro';
---

<header id="site-header">
  <div class="container header-container">
    <a href="/" class="logo">
      <Icon name="ph:house-line-duotone" class="logo-icon" />
      <span>Cout-Ravalement-Facade<span class="dot">.fr</span></span>
    </a>
    
    <nav class="desktop-nav">
      <a href="/estimation">Estimation</a>
      <a href="/guides">Guides</a>
      <a href="/materiaux">Matériaux</a>
      <a href="/annuaire">Artisans</a>
      <a href="/faq">FAQ</a>
      <a href="/estimation" class="btn btn-primary btn-sm-nav">Devis Gratuit</a>
    </nav>
    
    <button id="menu-toggle" aria-label="Menu principal" class="burger-btn">
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>
  </div>

  <MobileNav />
</header>

<style>
  #site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--card-bg);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
    height: 72px;
    display: flex;
    align-items: center;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--primary-dark);
  }

  .logo-icon {
    width: 28px;
    height: 28px;
    color: var(--accent);
  }

  .dot {
    color: var(--accent);
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .desktop-nav a {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .desktop-nav a:hover {
    color: var(--accent);
  }

  .btn-sm-nav {
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    border-radius: 8px;
  }

  .burger-btn {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 110;
  }

  .burger-bar {
    width: 24px;
    height: 2px;
    background-color: var(--primary-dark);
    transition: all 0.3s ease;
  }

  /* Sticky class on scroll */
  :global(#site-header.scrolled) {
    box-shadow: var(--shadow);
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    height: 64px;
  }

  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }

    .burger-btn {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
