---
import Icon from './Icon.astro';

interface Props {
  symptomes: string[];
  zoneClimatique: string;
  cityName: string;
}

const { symptomes, zoneClimatique, cityName } = Astro.props;
---

<div class="diag-checklist">
  <div class="diag-header">
    <Icon name="ph:wrench-duotone" class="diag-icon" />
    <div>
      <h4>Diagnostic Pathologique — Climat local à {cityName}</h4>
      <p class="diag-climate-tag">Zone d'influence : <strong>{zoneClimatique}</strong></p>
    </div>
  </div>
  
  <p class="intro-p">Inspectez attentivement vos parois extérieures. Si vous identifiez l'un des signes cliniques suivants, une intervention est recommandée afin de préserver l'intégrité de la structure :</p>
  
  <ul class="symptom-list">
    {symptomes.map((symptome) => (
      <li class="symptom-item">
        <Icon name="ph:warning-duotone" class="warn-bullet" />
        <span>{symptome}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .diag-checklist {
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
  }

  .diag-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 0.75rem;
  }

  .diag-icon {
    width: 32px;
    height: 32px;
    color: var(--accent);
  }

  .diag-header h4 {
    font-size: 1.15rem;
    color: var(--primary-dark);
    margin-bottom: 0.15rem;
  }

  .diag-climate-tag {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  .intro-p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  .symptom-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .symptom-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .warn-bullet {
    width: 18px;
    height: 18px;
    color: var(--danger);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
</style>
