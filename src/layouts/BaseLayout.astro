---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import StickyCTA from '../components/ui/StickyCTA.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}

const { title, description, schema } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="msvalidate.01" content="307B54BCA2CA95B3C6E06FCBA73E932E" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || 'https://cout-ravalement-facade.fr').toString()} />
    
    <!-- Security DNS Prefetches -->
    <link rel="dns-prefetch" href="//www.viteundevis.com" />
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />

    {schema && <SchemaOrg schema={schema} />}
  </head>
  <body>
    <Header />
    <main style="flex: 1;">
      <slot />
    </main>
    <Footer />
    <StickyCTA />
  </body>
</html>
