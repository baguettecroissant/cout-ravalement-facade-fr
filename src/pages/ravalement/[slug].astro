---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import CostBreakdown from '../../components/ui/CostBreakdown.astro';
import PropertyValueCard from '../../components/ui/PropertyValueCard.astro';
import DiagnosticChecklist from '../../components/ui/DiagnosticChecklist.astro';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';
import ViteUnDevisWidget from '../../components/affiliation/ViteUnDevisWidget.astro';
import Icon from '../../components/ui/Icon.astro';

import { 
  getCityH1, 
  getCityMetaTitle, 
  getCityMetaDescription, 
  getCityIntro, 
  getCityPrices, 
  getClimateProfile, 
  getObligationRavalement,
  getCityFAQ,
  getCitySignesAlerte,
  getCityContext,
  getZoneClimatiqueDTU,
  getLocalArchitectureContext,
  getCityExternalLinks,
  getEnergyAidsDetailed,
} from '../../lib/text-utils';

import { getNearbyCities, getDepartmentSlug, getCityBySlug } from '../../lib/cities';
import type { City } from '../../types/index';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return new Response('Not Found', { status: 404 });
}

const city = getCityBySlug(slug);

if (!city) {
  return Astro.redirect('/404');
}

const h1 = getCityH1(city);
const title = getCityMetaTitle(city);
const description = getCityMetaDescription(city);
const intro = getCityIntro(city);
const prices = getCityPrices(city);
const climate = getClimateProfile(city);
const obligation = getObligationRavalement(city);
const faq = getCityFAQ(city);
const alertes = getCitySignesAlerte(city);
const context = getCityContext(city);
const dtuZone = getZoneClimatiqueDTU(city);
const archi = getLocalArchitectureContext(city);
const externalLinks = getCityExternalLinks(city);
const aides = getEnergyAidsDetailed(city);

const nearby = getNearbyCities(city, 8);

// Build Breadcrumbs
const breadcrumbs = [
  { name: "Accueil", url: "/" },
  { name: `Ravalement ${city.department_name}`, url: `/annuaire/${getDepartmentSlug(city.department_code, city.department_name)}` },
  { name: city.name }
];

// Schema.org — Service + AggregateOffer
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Ravalement de Façade à ${city.name} — Devis Gratuit`,
  "description": description,
  "serviceType": "Ravalement de façade et isolation thermique extérieure (ITE)",
  "category": "Rénovation de bâtiment / Travaux extérieurs",
  "areaServed": {
    "@type": "City",
    "name": city.name,
    "containedInPlace": { 
      "@type": "AdministrativeArea", 
      "name": city.department_name,
      "containedInPlace": {
        "@type": "Country",
        "name": "France"
      }
    }
  },
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": `Artisans Façadiers RGE de ${city.name} (${city.department_name})`,
    "description": `Réseau de professionnels qualifiés RGE et Qualibat spécialisés dans le traitement et la rénovation de façade à ${city.name}.`,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": city.name,
      "postalCode": city.zip,
      "addressCountry": "FR"
    }
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "EUR",
    "lowPrice": prices.nettoyage.min,
    "highPrice": prices.ite.max,
    "offerCount": "12",
    "unitText": "par m² de façade (pose et fournitures inclus)"
  }
};

// Schema.org — FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

// Schema.org — BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    ...(b.url ? { "item": `https://cout-ravalement-facade.fr${b.url}` } : {})
  }))
};

const pageSchemas = [serviceSchema, faqSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} schema={pageSchemas}>
  <!-- Breadcrumb -->
  <Breadcrumb items={breadcrumbs} />

  <!-- City Hero -->
  <section class="city-hero">
    <div class="container hero-container">
      <!-- Zone + Context badges -->
      <div class="city-badges">
        <span class="badge badge-zone">
          <Icon name="ph:thermometer-duotone" class="badge-icon" />
          Zone DTU {dtuZone.code}
        </span>
        <span class="badge badge-context">
          <Icon name="ph:buildings-duotone" class="badge-icon" />
          {context.label} · {context.populationStr}
        </span>
        <span class="badge badge-dept">
          <Icon name="ph:map-pin-duotone" class="badge-icon" />
          {city.department_name} ({city.department_code})
        </span>
      </div>

      <h1 class="city-h1">{h1}</h1>
      <p class="city-intro-text" set:html={intro}></p>
      
      <div class="quick-cta-row">
        <a href="#estim-widget" class="btn btn-primary">
          <span>Obtenir mes devis gratuits à {city.name}</span>
          <Icon name="ph:arrow-right-duotone" class="arrow-icon" />
        </a>
        <a href="#faq-section" class="btn btn-outline">
          <Icon name="ph:question-duotone" class="arrow-icon" />
          <span>Questions fréquentes</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Main Grid Layout -->
  <div class="container page-content-grid">
    <div class="main-column flex-dom-container">

      <!-- ========================================== -->
      <!-- [DOM POSITION 1 — CSS visual order: 5]    -->
      <!-- SEO Text Block                            -->
      <!-- ========================================== -->
      <div class="seo-text-block order-5">

        <!-- Zone climatique DTU -->
        <div class="section-card dtu-card">
          <h2>Zone Climatique DTU {dtuZone.code} : Impacts sur vos façades à {city.name}</h2>
          <div class="dtu-badge-row">
            <span class="dtu-code-badge">{dtuZone.code}</span>
            <div>
              <strong>{dtuZone.label}</strong>
              <p class="dtu-hivernal">{dtuZone.hivernal}</p>
            </div>
          </div>
          <div class="note-info">
            <Icon name="ph:scales-duotone" class="note-icon" />
            <div class="note-content">
              <p><strong>Exigences réglementaires (DTU 26.2) :</strong> {dtuZone.exigences}</p>
            </div>
          </div>
          <div class="note-tip">
            <Icon name="ph:lightbulb-duotone" class="note-icon" />
            <div class="note-content">
              <p><strong>Isolation minimale recommandée :</strong> {dtuZone.isolationReq}</p>
            </div>
          </div>
        </div>

        <!-- Architecture locale -->
        <div class="section-card">
          <h2>Architecture Locale & Bâti Dominant à {city.name}</h2>
          <div class="archi-style-badge">
            <Icon name="ph:house-simple-duotone" class="archi-icon" />
            <span>{archi.style}</span>
          </div>
          <p>{archi.description}</p>
          <div class="archi-grid">
            <div class="archi-block">
              <h3 class="archi-subtitle">⚠️ Contraintes spécifiques</h3>
              <p>{archi.contraintes}</p>
            </div>
            <div class="archi-block">
              <h3 class="archi-subtitle">🔨 Matériaux recommandés</h3>
              <p>{archi.materiaux}</p>
            </div>
          </div>
        </div>

        <!-- Impact climatique -->
        <div class="section-card">
          <h2>Impact du Climat sur vos Façades à {city.name}</h2>
          <p>{climate.description}</p>
          <p><strong>Risques identifiés en zone {climate.zone} :</strong> {climate.risks}</p>
          <div class="note-info">
            <Icon name="ph:info-duotone" class="note-icon" />
            <div class="note-content">
              <p><strong>Recommandation technique :</strong> {climate.renderType}. {climate.advice}</p>
            </div>
          </div>
        </div>

        <!-- Réglementation municipale enrichie -->
        <div class="section-card">
          <h2>Obligations Légales de Ravalement à {city.name}</h2>
          <p>{obligation}</p>
          <div class="note-warning">
            <Icon name="ph:warning-duotone" class="note-icon" />
            <div class="note-content">
              <p><strong>Déclaration Préalable :</strong> Tout changement de couleur ou de matériau de façade à {city.name} nécessite une Déclaration Préalable de Travaux (CERFA n°13703). Délai d'instruction : 1 mois. Si votre bien est à moins de 500 m d'un Monument Historique, l'accord de l'Architecte des Bâtiments de France (ABF) est obligatoire.</p>
            </div>
          </div>
        </div>

        <!-- Diagnostic Checklist -->
        <DiagnosticChecklist 
          symptomes={alertes} 
          zoneClimatique={climate.zone} 
          cityName={city.name} 
        />

        <!-- Property Value Card -->
        <PropertyValueCard cityName={city.name} />

        <!-- FAQ localisée unique -->
        <div id="faq-section" class="section-card faq-section">
          <h2>Foire aux Questions — Ravalement de Façade à {city.name}</h2>
          <FaqAccordion faqItems={faq} />
        </div>

        <!-- Liens externes officiels -->
        <div class="section-card external-links-card">
          <h2>Ressources Officielles Utiles pour votre Projet à {city.name}</h2>
          <p>Ces liens vers des organismes officiels vous permettront de vérifier les aides disponibles, trouver des artisans certifiés et comprendre la réglementation applicable à {city.name} ({city.department_name}) :</p>
          <div class="external-links-grid">
            {externalLinks.map((link) => (
              <a 
                href={link.url} 
                target="_blank" 
                rel={link.rel}
                class="external-link-card"
              >
                <div class="ext-link-header">
                  <Icon name="ph:arrow-square-out-duotone" class="ext-icon" />
                  <span class="ext-link-label">{link.label}</span>
                </div>
                <p class="ext-link-desc">{link.description}</p>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- [DOM POSITION 2 — CSS visual order: 1]    -->
      <!-- Cost Breakdown                            -->
      <!-- ========================================== -->
      <div class="order-1">
        <CostBreakdown prices={prices} cityName={city.name} />
      </div>

      <!-- ========================================== -->
      <!-- [DOM POSITION 3 — CSS visual order: 2]    -->
      <!-- Grille de coûts par technique             -->
      <!-- ========================================== -->
      <div class="section-card order-2">
        <h2>Prix au m² par Technique de Ravalement à {city.name}</h2>
        <p>Tarifs moyens constatés en <strong>{city.department_name}</strong> en 2026, pose et fournitures incluses (zone climatique DTU <strong>{dtuZone.code}</strong>) :</p>
        
        <div class="pricing-m2-grid">
          <div class="m2-price-item">
            <span class="m2-tech">Nettoyage haute pression</span>
            <span class="m2-price mono">{prices.nettoyage.min} € – {prices.nettoyage.max} € / m²</span>
            <span class="m2-note">Démoussage + algicide</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Peinture façade (RPE/RPT)</span>
            <span class="m2-price mono">{prices.peinture.min} € – {prices.peinture.max} € / m²</span>
            <span class="m2-note">2 couches sur support sain</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Enduit monocouche projeté</span>
            <span class="m2-price mono">{prices.enduitMonocouche.min} € – {prices.enduitMonocouche.max} € / m²</span>
            <span class="m2-note">OC2 semi-allégé gratté ou taloché</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Enduit traditionnel 3 couches</span>
            <span class="m2-price mono">{prices.enduitTraditionnel.min} € – {prices.enduitTraditionnel.max} € / m²</span>
            <span class="m2-note">Gobetis + corps d'enduit + finition</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Enduit à la chaux naturelle</span>
            <span class="m2-price mono">{prices.enduitChaux.min} € – {prices.enduitChaux.max} € / m²</span>
            <span class="m2-note">NHL 2 ou NHL 3.5 — bâti ancien</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">ITE (isolation + enduit)</span>
            <span class="m2-price mono">{prices.ite.min} € – {prices.ite.max} € / m²</span>
            <span class="m2-note">PSE ou laine de roche + finition</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Bardage ventilé (bois/composite)</span>
            <span class="m2-price mono">{prices.bardage.min} € – {prices.bardage.max} € / m²</span>
            <span class="m2-note">Pose + ossature + isolation</span>
          </div>
          <div class="m2-price-item">
            <span class="m2-tech">Échafaudage (location + pose)</span>
            <span class="m2-price mono">{prices.echafaudage.min} € – {prices.echafaudage.max} € / m²</span>
            <span class="m2-note">Inclus dans tous les devis façade</span>
          </div>
        </div>

        <p class="pricing-note">* Ces prix sont donnés à titre indicatif pour la zone DTU <strong>{dtuZone.code}</strong> ({city.department_name}). Le devis définitif dépend de l'état du support, de la surface exacte à traiter et de l'accessibilité du chantier.</p>
      </div>

      <!-- ========================================== -->
      <!-- [DOM POSITION 4 — CSS visual order: 3]    -->
      <!-- Widget devis                              -->
      <!-- ========================================== -->
      <div id="estim-widget" class="order-3">
        <ViteUnDevisWidget />
      </div>

      <!-- ========================================== -->
      <!-- [DOM POSITION 5 — CSS visual order: 4]    -->
      <!-- Aides financières détaillées              -->
      <!-- ========================================== -->
      <div class="section-card order-4">
        <h2>Aides Financières et Subventions à {city.name} en 2026</h2>
        <p>En couplant votre ravalement à une <strong>Isolation Thermique par l'Extérieur (ITE)</strong>, vous devenez éligible à plusieurs dispositifs d'aides cumulables. Voici le détail des aides disponibles en {city.department_name} :</p>
        
        <div class="aides-grid">
          {aides.map((aide) => (
            <div class="aide-card">
              <div class="aide-header">
                <Icon name="ph:currency-eur-duotone" class="aide-icon" />
                <h3 class="aide-titre">{aide.titre}</h3>
              </div>
              <div class="aide-montant">{aide.montant}</div>
              <p class="aide-conditions">{aide.conditions}</p>
              <a href={aide.lien} target="_blank" rel="nofollow noopener noreferrer" class="aide-link">
                En savoir plus <Icon name="ph:arrow-square-out-duotone" class="aide-link-icon" />
              </a>
            </div>
          ))}
        </div>

        <div class="note-tip">
          <Icon name="ph:star-duotone" class="note-icon" />
          <div class="note-content">
            <p><strong>Conseil :</strong> Pour maximiser vos aides à {city.name}, déposez votre dossier MaPrimeRénov' <em>avant</em> le début des travaux. Un conseiller France Rénov' gratuit peut vous accompagner dans toutes vos démarches.</p>
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- [DOM POSITION 6 — CSS visual order: 6]    -->
      <!-- Villes proches                            -->
      <!-- ========================================== -->
      <div class="section-card order-6">
        <h2>Communes Voisines de {city.name} — Façadiers Locaux</h2>
        <p>Consultez les estimations et trouvez des façadiers qualifiés dans les communes proches de {city.name} ({city.department_name}) :</p>
        <div class="nearby-grid">
          {nearby.map((nc) => (
            <a href={`/ravalement/${nc.slug}`} class="nearby-link">
              <Icon name="ph:map-pin-duotone" class="nearby-icon" />
              <span>{nc.name} ({nc.zip})</span>
            </a>
          ))}
        </div>
        <p class="nearby-note">
          → <a href={`/annuaire/${getDepartmentSlug(city.department_code, city.department_name)}`}>
            Voir tous les artisans façadiers du {city.department_name}
          </a>
        </p>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── City Hero ── */
  .city-hero {
    background: linear-gradient(135deg, var(--bg-alt) 0%, color-mix(in srgb, var(--primary-dark) 4%, var(--bg-alt)) 100%);
    border-bottom: 1px solid var(--border);
    padding: 3.5rem 0 3rem;
  }

  .hero-container {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Badges */
  .city-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid;
  }

  .badge-icon {
    width: 14px;
    height: 14px;
  }

  .badge-zone {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    color: var(--accent);
  }

  .badge-context {
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    color: var(--primary-dark);
  }

  .badge-dept {
    background: color-mix(in srgb, var(--text-secondary) 8%, transparent);
    border-color: var(--border);
    color: var(--text-secondary);
  }

  .city-h1 {
    font-size: 2.1rem;
    color: var(--primary-dark);
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .city-intro-text {
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .city-intro-text strong {
    color: var(--primary-dark);
  }

  .quick-cta-row {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .arrow-icon {
    width: 18px;
    height: 18px;
  }

  /* ── Main Grid ── */
  .page-content-grid {
    padding: 4rem 1.5rem;
  }

  .main-column {
    max-width: 820px;
    margin: 0 auto;
  }

  .flex-dom-container {
    display: flex;
    flex-direction: column;
  }

  .order-1 { order: 1; }
  .order-2 { order: 2; }
  .order-3 { order: 3; }
  .order-4 { order: 4; }
  .order-5 { order: 5; }
  .order-6 { order: 6; }

  /* ── Section Cards ── */
  .section-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .section-card h2 {
    font-size: 1.45rem;
    color: var(--primary-dark);
    margin-bottom: 1.25rem;
    border-bottom: 2px solid var(--border-light);
    padding-bottom: 0.5rem;
    line-height: 1.3;
  }

  .section-card h3 {
    font-size: 1rem;
    color: var(--primary-dark);
    margin-bottom: 0.5rem;
  }

  .section-card p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .section-card ul {
    list-style-type: none;
    margin-left: 0;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .section-card ul li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .section-card ul li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  /* ── Notes / callouts ── */
  .note-info, .note-tip, .note-warning {
    display: flex;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    margin-top: 1rem;
    border: 1px solid;
  }

  .note-info {
    background: color-mix(in srgb, var(--primary) 8%, transparent);
    border-color: color-mix(in srgb, var(--primary) 25%, transparent);
  }

  .note-tip {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .note-warning {
    background: color-mix(in srgb, #f59e0b 8%, transparent);
    border-color: color-mix(in srgb, #f59e0b 30%, transparent);
  }

  .note-icon {
    width: 22px;
    height: 22px;
    color: var(--primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .note-tip .note-icon { color: var(--accent); }
  .note-warning .note-icon { color: #d97706; }

  .note-content p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  /* ── DTU Zone card ── */
  .dtu-card {
    border-left: 4px solid var(--accent);
  }

  .dtu-badge-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .dtu-code-badge {
    background: var(--accent);
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
    padding: 0.4rem 0.875rem;
    border-radius: 8px;
    flex-shrink: 0;
    letter-spacing: 0.02em;
    font-family: monospace;
  }

  .dtu-hivernal {
    margin: 0.25rem 0 0 0 !important;
    font-size: 0.88rem !important;
  }

  /* ── Architecture block ── */
  .archi-style-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--primary-dark) 8%, transparent);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.875rem;
    margin-bottom: 1rem;
    font-weight: 600;
    color: var(--primary-dark);
    font-size: 0.9rem;
  }

  .archi-icon {
    width: 18px;
    height: 18px;
    color: var(--primary);
    flex-shrink: 0;
  }

  .archi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  .archi-block {
    background: var(--bg-alt);
